# Configurações do Backend PEC

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://projeto-saude-saude-frontend.gkgtsp.easypanel.host/

# APIs de IA (modo demonstração - sem chaves reais)
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Banco de Dados
DATABASE_URL=postgresql://admin:password@localhost:5432/saude?sslmode=disable

# JWT
JWT_SECRET=pec-dev-secret-key
JWT_EXPIRES_IN=24h
