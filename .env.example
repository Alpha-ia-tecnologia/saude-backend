# Configurações do Backend PEC

# Banco de Dados (PostgreSQL)
DATABASE_URL=postgresql://admin:password@localhost:5432/saude?sslmode=disable

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# APIs de IA (preencher com suas chaves)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# JWT (para autenticação futura)
JWT_SECRET=pec-secret-key-change-in-production
JWT_EXPIRES_IN=24h
